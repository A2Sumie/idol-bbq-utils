model task_queue {
  id         Int    @id @default(autoincrement())
  type       String
  payload    Json
  status     String @default("pending") // pending, processing, completed, failed
  created_at Int
  updated_at Int    @default(0)
  execute_at Int
  finished_at Int?
  last_error String?
  result_summary String?
  source_ref String?
  action_type String?
  idempotency_key String?
  
  @@index([status, execute_at])
  @@unique([type, idempotency_key])
}

model processor_runs {
  id           Int    @id @default(autoincrement())
  processor_id String?
  action       String
  source_type  String?
  source_ref   String?
  status       String @default("completed")
  input        Json?
  output       Json?
  error        String?
  created_at   Int
  finished_at  Int?

  @@index([processor_id, created_at(sort: Desc)])
  @@index([source_ref, created_at(sort: Desc)])
}

model crawler_follows {
  id         Int    @id @unique(map: "sqlite_autoindex_crawler_follows_1") @default(autoincrement())
  username   String
  u_id       String
  platform   Int
  followers  Int
  created_at Int

  @@index([u_id], map: "user_id_index")
}

// Keeping this for deduplication / tracking sent messages
model forward_by {
  ref_id    Int // Note: This might need to track platform now, or assume global ID uniqueness if we had one (we don't). So better add platform or use combined key.
  // Actually, let's make it generic string based ID for flexibility across tables?
  // Or: platform + article_id (int)
  platform  String 
  bot_id    String
  task_type String

  @@id([ref_id, platform, bot_id, task_type])
  @@index([bot_id], map: "bot_id_index")
}

model media_hashes {
  id         Int    @id @default(autoincrement())
  platform   String
  hash       String
  a_id       String @default("")
  created_at Int

  @@unique([platform, hash], map: "platform_hash_unique")
  @@index([hash])
}

model outbound_messages {
  id                   Int     @id @default(autoincrement())
  idempotency_key      String  @unique
  route_key            String
  target_id            String
  target_platform      String?
  task_kind            String
  article_key          String?
  synthetic_key        String?
  payload_hash         String
  status               String  @default("planned")
  provider_message_ids Json?
  segment_results      Json?
  attempt_count        Int     @default(0)
  last_error           String?
  created_at           Int
  updated_at           Int
  finished_at          Int?

  @@index([target_id, status])
  @@index([route_key, task_kind])
  @@index([article_key])
  @@index([synthetic_key])
}

model aggregation_windows {
  id              Int     @id @default(autoincrement())
  idempotency_key String  @unique
  route_key       String
  target_id       String
  mode            String
  window_start    Int
  window_end      Int
  status          String  @default("open")
  payload_hash    String?
  created_at      Int
  updated_at      Int
  finished_at     Int?

  items aggregation_items[]

  @@index([route_key, mode, status])
  @@index([target_id, mode, status])
}

model aggregation_items {
  id             Int     @id @default(autoincrement())
  window_id      Int
  article_key    String
  article_row_id Int
  platform       String
  payload        Json?
  created_at     Int

  window aggregation_windows @relation(fields: [window_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([window_id, article_key])
  @@index([article_key])
}

model target_health {
  target_id          String @id
  provider           String
  status             String
  last_send_status   String?
  last_provider_code String?
  disabled_reason    String?
  details            Json?
  checked_at         Int
  updated_at         Int
}
