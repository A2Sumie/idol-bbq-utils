{
    "name": "idol-bbq-utils",
    "version": "0.3.2-custom",
    "description": "",
    "main": "index.js",
    "scripts": {
        "start:forwarder": "bun --filter @idol-bbq-utils/tweet-forwarder start",
        "build:forwarder": "bun --filter @idol-bbq-utils/tweet-forwarder build",
        "audit:config": "bun app/tweet-forwarder/scripts/config-audit.ts --config assets/config.yaml",
        "deploy:forwarder:stopped": "tools/deploy-forwarder-stopped.sh",
        "preflight:forwarder": "tools/forwarder-preflight.sh",
        "drill:db-backup": "tools/forwarder-db-backup-drill.sh",
        "drill:forwarder-db-backup": "tools/forwarder-db-backup-drill.sh",
        "audit:remote-drift": "tools/forwarder-remote-drift.sh",
        "audit:forwarder-remote-drift": "tools/forwarder-remote-drift.sh",
        "converge:remote-source": "tools/forwarder-remote-converge.sh",
        "converge:forwarder-remote": "tools/forwarder-remote-converge.sh",
        "verify:forwarder": "tools/forwarder-green-gate.sh",
        "format": "pnpm prettier --write . --ignore-path .prettierignore",
        "docs:dev": "bun --filter docs dev",
        "docs:build": "bun --filter docs build",
        "docs:preview": "bun --filter docs preview"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@types/bun": "^1.2.13",
        "prettier": "^3.3.2",
        "typescript": "^5.5.3"
    },
    "workspaces": [
        "core/*",
        "app/*",
        "docs/*"
    ]
}
